# Template — ClusterIP for the api pod. Tokens: <NAMESPACE>, <SERVICE_NAME>, <PORT>
apiVersion: v1
kind: Service
metadata:
  name: <SERVICE_NAME>-api
  namespace: <NAMESPACE>
  labels:
    app: <SERVICE_NAME>-api
spec:
  type: ClusterIP
  selector:
    app: <SERVICE_NAME>-api
  ports:
    - name: http
      port: 80
      targetPort: <PORT>
      protocol: TCP
