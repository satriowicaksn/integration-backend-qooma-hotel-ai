# ============================================================================
# Qooma Backend Service — Environment Variables (Template)
# ============================================================================
# Salin ke .env (untuk dev lokal) atau set di secret manager (AWS Secrets
# Manager untuk prod). JANGAN commit .env asli.
# ============================================================================

# --- Runtime ---
NODE_ENV=development                    # development | staging | production
LOG_LEVEL=debug                         # debug | info | warn | error
TZ=UTC                                  # Selalu UTC di runtime; konversi tampilan di layer presentasi

# --- HTTP Server (api process) ---
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173       # Daftar origin pisah koma kalau >1

# --- Database (1 service = 1 DB) ---
# Host port 5433 untuk menghindari bentrok dengan Postgres lokal (Postgres.app /
# Homebrew) di 5432. Container internal port tetap 5432 di docker-compose.
DATABASE_URL=postgresql://app:app_dev_pw@localhost:5433/app?schema=public

# --- Redis (queue + cache) ---
# Host port 6380 untuk menghindari bentrok dengan Redis lokal di 6379.
REDIS_URL=redis://localhost:6380
REDIS_QUEUE_DB=0
REDIS_CACHE_DB=1
REDIS_TLS_ENABLED=false                 # true di prod (Elasticache/Upstash)

# --- Security ---
JWT_ACCESS_SECRET=replace_min_32_chars_random_dev_only
JWT_ACCESS_TTL=8h
JWT_REFRESH_SECRET=replace_min_32_chars_random_dev_only
JWT_REFRESH_TTL=30d
ENCRYPTION_KEY=replace_64_hex_chars_for_aes_256_gcm_dev_only
ENCRYPTION_KEY_VERSION=v1
# Dev/MVP: {"my-hotel-slug":"11111111-2222-3333-4444-555555555555"}
TELEGRAM_WEBHOOK_HOTEL_SLUG_MAP=
# Dev/MVP: {"dept-hk-01":"11111111-2222-3333-4444-555555555555"}
TELEGRAM_DEPT_ROUTING_MAP=

# --- Rate Limiting ---
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_WEBHOOK_PER_MIN=300

# --- Observability ---
SENTRY_DSN=                             # Kosongkan = disabled
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENV=development

# --- Worker tuning ---
WORKER_CONCURRENCY_DEFAULT=5

# ============================================================================
# Service-specific env (tambah di bawah sesuai kebutuhan service Anda)
# ============================================================================
# Contoh (uncomment & sesuaikan):
#
# # AI provider
# ANTHROPIC_API_KEY=sk-ant-replace
# OPENAI_API_KEY=sk-replace
#
# # Object storage
# S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
# S3_REGION=ap-southeast-1
# S3_BUCKET=app-media
# S3_ACCESS_KEY_ID=replace
# S3_SECRET_ACCESS_KEY=replace
#
# # External HTTP API
# UPSTREAM_API_BASE=https://api.example.com
# UPSTREAM_WEBHOOK_SECRET=replace_for_hmac
