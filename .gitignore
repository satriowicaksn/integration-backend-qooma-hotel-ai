# ============================================================================
# Qooma Core Backend .gitignore
# ============================================================================

# --- Dependencies ---
node_modules/
.pnpm-store/
.npm/
jspm_packages/

# --- Build output ---
dist/
build/
*.tsbuildinfo
.tsbuildinfo

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Runtime ---
pids/
*.pid
*.seed
*.pid.lock

# --- Test & Coverage ---
coverage/
*.lcov
.nyc_output/
.jest-cache/

# --- IDE / Editor ---
.vscode/*
!.vscode/settings.example.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# --- Prisma generated client (re-generated saat install) ---
src/core/prisma/generated/
node_modules/.prisma/

# --- Caches ---
.cache/
.eslintcache
.stylelintcache
.parcel-cache

# --- Local dev volumes ---
.postgres-data/
.redis-data/
.minio-data/
docker/volumes/

# --- Misc ---
*.tgz
.node_repl_history
.yarn-integrity
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# --- AI assistant local state ---
.claude/local.json
.claude/session/
